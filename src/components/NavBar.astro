---
import { Image } from 'astro:assets';
import logoSrc from '../assets/adventist_symbol_denim.png';
const currentPath = Astro.url.pathname;
const links = [
  { id: 'home',       label: 'Início',          href: '/' },
  { id: 'historia',   label: 'Nossa história',   href: '/historia' },
  { id: 'ministerios',label: 'Ministérios',      href: '/ministerios/jovens' },
  { id: 'conhecer',   label: 'Quero conhecer',   href: '/quero-conhecer' },
];
---

<nav id="main-nav" class="nav">
  <div class="container nav__inner">
    <!-- Brand -->
    <a href="/" class="nav__brand" aria-label="Início">
      <Image src={logoSrc} alt="Logo IASD" class="nav__brand-mark" width={32} height={32} />
      <span class="nav__brand-text">
        <b>IASD Niterói</b>
        <span>Canoas · RS</span>
      </span>
    </a>

    <!-- Desktop links -->
    <div class="nav__links">
      {links.map(l => (
        <a href={l.href} class={currentPath === l.href || (l.href !== '/' && currentPath.startsWith(l.href)) ? 'active' : ''}>
          {l.label}
        </a>
      ))}
    </div>

    <!-- CTA + mobile toggle -->
    <div class="nav__right">
      <a href="/quero-conhecer" class="btn btn--primary nav__cta">
        Planeje sua visita <span class="arr">→</span>
      </a>
      <button id="mobile-menu-btn" class="nav__hamburger" aria-label="Abrir menu" aria-expanded="false">
        <span id="icon-menu">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <line x1="3" y1="7" x2="19" y2="7"/><line x1="3" y1="11" x2="19" y2="11"/><line x1="3" y1="15" x2="19" y2="15"/>
          </svg>
        </span>
        <span id="icon-close" class="hidden">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <line x1="5" y1="5" x2="17" y2="17"/><line x1="17" y1="5" x2="5" y2="17"/>
          </svg>
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="nav__mobile hidden">
    {links.map(l => (
      <a href={l.href} class={currentPath === l.href || (l.href !== '/' && currentPath.startsWith(l.href)) ? 'active' : ''}>
        {l.label}
      </a>
    ))}
    <a href="/quero-conhecer" class="btn btn--primary" style="margin-top: 8px;">
      Planeje sua visita →
    </a>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(249,249,249,0.80);
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    transition: box-shadow var(--t-fast);
  }
  .nav.scrolled { box-shadow: 0 4px 32px -8px rgba(0,30,64,0.06); }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 18px;
    padding-bottom: 18px;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .nav__brand-mark { width: 32px; height: 32px; flex-shrink: 0; }
  .nav__brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .nav__brand-text b {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 17px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .nav__brand-text span {
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-top: 2px;
  }

  .nav__links {
    display: flex;
    gap: 4px;
    align-items: center;
  }
  .nav__links a {
    padding: 9px 14px;
    font-size: 13.5px;
    color: var(--ink-soft);
    border-radius: 0.375rem;
    transition: color var(--t-fast), background var(--t-fast);
  }
  .nav__links a:hover { color: var(--ink); background: var(--bg-soft); }
  .nav__links a.active { color: var(--ink); }
  .nav__links a.active::after {
    content: "";
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    margin: 4px auto 0;
  }

  .nav__right { display: flex; align-items: center; gap: 12px; }
  .nav__cta { font-size: 13px; }

  .nav__hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--ink-soft);
    line-height: 0;
  }
  .hidden { display: none !important; }

  .nav__mobile {
    background: rgba(249,249,249,0.97);
    padding: 16px var(--gutter) 20px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .nav__mobile a {
    padding: 10px 4px;
    font-size: 15px;
    color: var(--ink-soft);
  }
  .nav__mobile a.active { color: var(--ink); font-weight: 500; }

  @media (max-width: 820px) {
    .nav__links { display: none; }
    .nav__cta { display: none; }
    .nav__hamburger { display: block; }
  }
</style>

<script>
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 8);
  }, { passive: true });

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
