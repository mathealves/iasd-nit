---
---

<section class="max-w-7xl mx-auto px-8 mb-20" aria-labelledby="horarios-titulo">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Wednesday -->
    <div
      class="bg-surface-container-lowest p-10 rounded-xl transition-all duration-300 hover:shadow-xl group border border-surface-container"
    >
      <div class="flex justify-between items-start mb-12">
        <span class="material-symbols-outlined text-secondary text-3xl">auto_awesome</span>
        <div class="text-right">
          <span class="block noto-serif text-3xl text-primary font-bold">Quarta-feira</span>
        </div>
      </div>
      <div class="space-y-8">
        <div class="flex items-center justify-between border-b border-surface-container py-4">
          <div>
            <h3 class="font-bold text-primary">Culto</h3>
            <p class="text-sm text-on-surface-variant">Adoração e Mensagem</p>
          </div>
          <span class="noto-serif text-xl text-secondary">20:00</span>
        </div>
      </div>
    </div>

    <!-- Saturday (The Sabbath) — highlighted -->
    <div
      class="bg-primary-container p-10 rounded-xl lg:scale-105 shadow-2xl relative overflow-hidden"
    >
      <div class="absolute top-0 right-0 p-4 opacity-10 pointer-events-none">
        <span class="material-symbols-outlined text-[120px]" style="font-variation-settings: 'FILL' 1;">wb_sunny</span>
      </div>
      <div class="relative z-10">
        <div class="flex justify-between items-start mb-12">
          <span
            class="material-symbols-outlined text-secondary-fixed text-4xl"
            style="font-variation-settings: 'FILL' 1;"
          >verified</span>
          <div class="text-right">
            <span class="block noto-serif text-3xl text-on-primary font-bold">Sábado</span>
          </div>
        </div>
        <div class="space-y-8">
          <div
            class="flex items-center justify-between border-b border-on-primary-fixed-variant py-4"
          >
            <div>
              <h3 class="font-bold text-on-primary">Escola Sabatina</h3>
              <p class="text-sm text-on-primary-container">Estudo Bíblico em Grupos</p>
            </div>
            <span class="noto-serif text-xl text-secondary-fixed">09:00</span>
          </div>
          <div class="flex items-center justify-between py-4">
            <div>
              <h3 class="font-bold text-on-primary">Culto</h3>
              <p class="text-sm text-on-primary-container">Adoração e Mensagem</p>
            </div>
            <span class="noto-serif text-xl text-secondary-fixed">10:30</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Sunday -->
    <div
      class="bg-surface-container-lowest p-10 rounded-xl transition-all duration-300 hover:shadow-xl border border-surface-container"
    >
      <div class="flex justify-between items-start mb-12">
        <span class="material-symbols-outlined text-secondary text-3xl">nightlight</span>
        <div class="text-right">
          <span class="block noto-serif text-3xl text-primary font-bold">Domingo</span>
        </div>
      </div>
      <div class="space-y-8">
        <div class="flex items-center justify-between border-b border-surface-container py-4">
          <div>
            <h3 class="font-bold text-primary">Culto</h3>
            <p class="text-sm text-on-surface-variant">Adoração e Mensagem</p>
          </div>
          <span class="noto-serif text-xl text-secondary">19:00</span>
        </div>
      </div>
    </div>
  </div>
</section>
