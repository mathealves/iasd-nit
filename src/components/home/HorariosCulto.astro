---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import programacao from '../../assets/programacao.jpeg';

const days = [
  {
    day: 'Quarta-feira',
    icon: 'lucide:sparkles',
    highlight: false,
    services: [{ title: 'Culto', desc: 'Adoração e Mensagem', time: '20:00' }],
  },
  {
    day: 'Sábado',
    icon: 'lucide:book-open',
    highlight: true,
    services: [
      { title: 'Escola Sabatina', desc: 'Estudo Bíblico em Grupos', time: '09:00' },
      { title: 'Culto', desc: 'Adoração e Mensagem', time: '10:30' },
    ],
  },
  {
    day: 'Domingo',
    icon: 'lucide:moon',
    highlight: false,
    services: [{ title: 'Culto', desc: 'Adoração e Mensagem', time: '19:00' }],
  },
];
---

<section class="section" id="horarios">
  <div class="container flex flex-col">
    <div class="reveal section__head" style="transition-delay: 120ms">
      <h1 class="schedule__title">
        Nossos <em>horários</em>
      </h1>
      <div class="reveal" style="transition-delay: 240ms">
        <p class="schedule__lede">
          Participe dos nossos cultos e atividades semanais. Uma oportunidade de crescer na fé,
          encontrar amigos e se conectar com Deus. Todos são bem-vindos!
        </p>
      </div>
    </div>

    <div class="schedule">
      {
        days.map((d, i) => (
          <div
            class={`reveal schedule__card${d.highlight ? ' schedule__card--highlight' : ''}`}
            style={`transition-delay: ${i * 120}ms`}
          >
            <div class="schedule__header">
              <span class="schedule__icon" aria-hidden="true">
                <Icon name={d.icon} size={22} />
              </span>
              <h2 class="schedule__day">{d.day}</h2>
            </div>

            <div class="schedule__services">
              {d.services.map((s, si) => (
                <div
                  class={`schedule__service${si < d.services.length - 1 ? ' schedule__service--bordered' : ''}`}
                >
                  <div class="schedule__service-info">
                    <span class="schedule__service-title">{s.title}</span>
                    <span class="schedule__service-desc">{s.desc}</span>
                  </div>
                  <span class="schedule__time">{s.time}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
    <div class="reveal"><span class="kicker">Programação <em>02/05 - 09/05</em> </span></div>

    <Image
      src={programacao}
      alt="Programação de 02/05 a 09/05"
      class="reveal"
      style={{ marginTop: '32px', borderRadius: '1rem' }}
    />
  </div>
</section>

<style>
  .section__head {
    max-width: 720px;
    margin-bottom: 56px;
  }

  .schedule__title {
    font-size: clamp(44px, 2vw, 76px);
    letter-spacing: -0.015em;
    font-weight: 500;
    margin-top: 22px;
    line-height: 1.05;
  }

  .schedule__lede {
    margin-top: 24px;
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 46ch;
  }

  .schedule {
    display: grid;
    grid-template-columns: 1fr 1.08fr 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  .schedule__card {
    padding: 36px 32px 40px;
    border-radius: 1rem;
    background: var(--bg-card);
    box-shadow: 0 8px 32px -8px rgba(0, 30, 64, 0.08);
    transition:
      box-shadow var(--t-med),
      transform var(--t-med);
  }
  .schedule__card:hover {
    box-shadow: 0 16px 48px -8px rgba(0, 30, 64, 0.14);
    transform: translateY(-3px);
  }

  .schedule__card--highlight {
    background: #0f2a5e;
    box-shadow: 0 24px 64px -12px rgba(15, 42, 94, 0.4);
    padding: 44px 36px 48px;
    color: #fff;
  }
  .schedule__card--highlight:hover {
    box-shadow: 0 32px 72px -8px rgba(15, 42, 94, 0.5);
  }

  /* Header row: icon + day name */
  .schedule__header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
  }
  .schedule__icon {
    flex-shrink: 0;
    color: var(--gold);
  }
  .schedule__card--highlight .schedule__icon {
    color: var(--gold);
  }
  .schedule__day {
    font-family: var(--serif);
    font-size: 1.65rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }
  .schedule__card--highlight .schedule__day {
    color: #fff;
  }

  /* Service rows */
  .schedule__services {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .schedule__service {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 0;
  }
  .schedule__service--bordered {
    border-bottom: 1px solid rgba(0, 30, 64, 0.08);
  }
  .schedule__card--highlight .schedule__service--bordered {
    border-bottom-color: rgba(255, 255, 255, 0.12);
  }

  .schedule__service-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .schedule__service-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
  }
  .schedule__card--highlight .schedule__service-title {
    color: #fff;
  }
  .schedule__service-desc {
    font-size: 13px;
    color: var(--ink-soft);
  }
  .schedule__card--highlight .schedule__service-desc {
    color: rgba(255, 255, 255, 0.6);
  }

  .schedule__time {
    font-family: var(--serif);
    font-size: 1.2rem;
    color: var(--gold);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .schedule__card--highlight .schedule__time {
    color: var(--gold);
  }

  .schedule__banner {
    margin-top: 32px;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 8px 32px -8px rgba(0, 30, 64, 0.08);
  }
  @media (max-width: 820px) {
    .schedule {
      grid-template-columns: 1fr;
    }
  }
</style>
