---
const items = [
  {
    day: "Sábado",
    time: "09:00",
    title: "Escola Sabatina",
    desc: "Estudo da Bíblia em pequenos grupos. Tem turma para todas as idades, inclusive para quem nunca abriu uma Bíblia.",
  },
  {
    day: "Sábado",
    time: "10:30",
    title: "Culto Divino",
    desc: "O encontro principal da semana. Música, oração, uma mensagem da Palavra e tempo para se conectar com a comunidade.",
  },
  {
    day: "Quarta",
    time: "20:00",
    title: "Reunião de Oração",
    desc: "Um encontro mais íntimo no meio da semana. Estudo curto, oração coletiva e espaço para compartilhar pedidos.",
  },
];
---

<section class="section" id="horarios">
  <div class="container">
    <div class="section__head">
      <div class="reveal"><span class="kicker">Programação semanal</span></div>
      <div class="reveal" style="transition-delay: 120ms">
        <h2 class="section__title">
          Três encontros por semana.<br /><em>Vem do jeito que dá.</em>
        </h2>
      </div>
    </div>

    <div class="schedule">
      {items.map((it, i) => (
        <div class="reveal schedule__card" style={`transition-delay: ${i * 120}ms`}>
          <div class="schedule__head">
            <span class="schedule__day">{it.day}</span>
            <span class="schedule__time">{it.time}</span>
          </div>
          <h3 class="schedule__title">{it.title}</h3>
          <p class="schedule__desc">{it.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section__head { max-width: 720px; margin-bottom: 56px; }
  .section__title {
    font-size: clamp(32px, 4vw, 52px);
    margin-top: 14px;
    font-weight: 400;
    letter-spacing: -0.015em;
  }
  .section__title em { font-style: italic; color: var(--accent); }

  .schedule {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }
  .schedule__card {
    padding: 40px 36px 44px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--bg-card);
    transition: background var(--t-fast);
  }
  .schedule__card:hover { background: var(--bg-soft); }

  .schedule__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 28px;
  }
  .schedule__day {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .schedule__time {
    font-family: var(--serif);
    font-size: 28px;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .schedule__title {
    font-size: 24px;
    margin-bottom: 12px;
    font-weight: 400;
    font-family: var(--serif);
  }
  .schedule__desc {
    font-size: 14.5px;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  @media (max-width: 820px) {
    .schedule { grid-template-columns: 1fr; }
  }
</style>
