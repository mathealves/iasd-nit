---
---

<section class="max-w-7xl mx-auto px-8 py-32" id="contato" aria-labelledby="contato-titulo">
  <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-16">
    <div>
      <h2 id="contato-titulo" class="noto-serif text-4xl text-primary font-bold mb-8">
        Nossa Localização
      </h2>

      <div class="space-y-6">
        <div class="flex gap-4">
          <span class="material-symbols-outlined text-secondary shrink-0">location_on</span>
          <div>
            <h5 class="font-bold text-primary">Igreja Niterói</h5>
            <p class="text-on-surface-variant">Bairro Niterói<br />Canoas, RS</p>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="material-symbols-outlined text-secondary shrink-0">phone_in_talk</span>
          <div>
            <h5 class="font-bold text-primary">Contato</h5>
            <p class="text-on-surface-variant">
              Entre em contato para mais informações sobre as atividades locais.
            </p>
            <div class="flex gap-4 mt-4">
              <a href="tel:#" class="text-primary hover:text-secondary transition-colors" title="Telefone">
                <span class="material-symbols-outlined">phone_in_talk</span>
              </a>
              <a href="https://instagram.com/iasdniteroi" target="_blank" rel="noopener noreferrer"
                 class="text-primary hover:text-secondary transition-colors" title="Instagram">
                <span class="material-symbols-outlined">camera_alt</span>
              </a>
              <a href="https://youtube.com/@iasdniteroi" target="_blank" rel="noopener noreferrer"
                 class="text-primary hover:text-secondary transition-colors" title="YouTube">
                <span class="material-symbols-outlined">video_library</span>
              </a>
              <a href="https://wa.me/5551999999999" target="_blank" rel="noopener noreferrer"
                 class="text-primary hover:text-secondary transition-colors" title="WhatsApp">
                <span class="material-symbols-outlined">chat</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-12">
        <a
          href="https://maps.google.com"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary text-on-primary px-8 py-4 rounded-lg font-bold transition-all hover:shadow-lg inline-flex items-center gap-3"
        >
          Ver no Mapa
          <span class="material-symbols-outlined text-sm">open_in_new</span>
        </a>
      </div>
    </div>

    <div class="h-[450px] bg-surface-container-low rounded-xl overflow-hidden shadow-inner grayscale contrast-125 hover:grayscale-0 transition-all duration-700 flex items-center justify-center">
      <div class="text-center px-6">
        <span class="material-symbols-outlined text-on-surface-variant text-5xl mb-3 block">map</span>
        <p class="text-on-surface-variant text-sm font-medium">Mapa será adicionado em breve</p>
      </div>
    </div>
  </div>
</section>
