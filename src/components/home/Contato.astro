---

<section class="section" id="contato" aria-labelledby="contato-titulo">
  <div class="container">
    <!-- Visit CTA box -->
    <div class="reveal visit-cta__box">
      <div>
        <span class="kicker" style="color: var(--bg);">Primeira vez?</span>
        <h2 class="visit-cta__title">
          A gente preparou<br />uma página <em>só pra você</em>.
        </h2>
        <p class="visit-cta__lede">
          Respondemos as perguntas que mais ouvimos: o que vestir, quanto
          tempo dura, se tem estacionamento, se vão te pressionar. (Não vão.)
        </p>
      </div>
      <a href="/quero-conhecer" class="btn visit-cta__btn">
        Quero conhecer <span class="arr">→</span>
      </a>
    </div>

    <!-- Location + map -->
    <div class="grid-2 contato__grid" style="margin-top: 80px; align-items: center;">
      <div class="reveal contato__info">
        <h2 id="contato-titulo" class="contato__heading">Nossa Localização</h2>

        <div class="contato__row">
          <div class="contato__label">Endereço</div>
          <div>
            <p>Bairro Niterói</p>
            <p>Canoas — RS</p>
          </div>
        </div>

        <div class="contato__row">
          <div class="contato__label">Contato</div>
          <div>
            <p>Entre em contato para mais informações sobre as atividades.</p>
            <div class="contato__social">
              <a href="tel:#" title="Telefone" aria-label="Telefone">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.8 19.79 19.79 0 01.07 1.18 2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
              </a>
              <a href="https://instagram.com/iasdniteroi" target="_blank" rel="noopener noreferrer" title="Instagram" aria-label="Instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
              <a href="https://youtube.com/@iasdniteroi" target="_blank" rel="noopener noreferrer" title="YouTube" aria-label="YouTube">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
              </a>
              <a href="https://wa.me/5551999999999" target="_blank" rel="noopener noreferrer" title="WhatsApp" aria-label="WhatsApp">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <a href="https://maps.google.com" target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="margin-top: 32px;">
          Ver no Mapa <span class="arr">→</span>
        </a>
      </div>

      <div class="reveal contato__map" style="transition-delay: 150ms">
        <div class="framed" style="height: 420px;">
          <img
            alt="Mapa de localização Niterói"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBkG6AHTP90bFfwltoQxzlUj6aPpP9Dxpprk1rzvdMHC-lnMNxEXNf19tj3bRfJn0zk-YLxv_Nxs3J7XaI1Y00r5xeBemy06UizKpLbYLchqAG__0IoUudJtO3ZtdpnB0UXStNKmbpP3bV-cq1evljg6gRc1MzajAaDDP6QP_Pcr3GBjUZ1bixh0JLeXEOKQWGzmO9AYWHosI2En2Zdx4T-N2bMem62k4xB98_dbz7mV9MTnyTOeHwCiYc_LvUuacIt-IsTAib0JnIY"
            style="filter: grayscale(0.6) contrast(1.1); width: 100%; height: 100%; object-fit: cover;"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .visit-cta__box {
    background: linear-gradient(45deg, var(--accent-deep) 0%, var(--accent) 100%);
    color: var(--bg);
    padding: 72px 64px;
    border-radius: 0.75rem;
    display: grid;
    grid-template-columns: 1.3fr auto;
    gap: 48px;
    align-items: end;
  }
  .visit-cta__title {
    font-family: var(--serif);
    font-size: clamp(28px, 3.5vw, 46px);
    font-weight: 400;
    color: var(--bg);
    margin-top: 14px;
    letter-spacing: -0.015em;
    line-height: 1.1;
  }
  .visit-cta__title em { font-style: italic; color: var(--gold); }
  .visit-cta__lede {
    margin-top: 20px;
    color: rgba(255,255,255,0.78);
    font-size: 17px;
    max-width: 50ch;
    line-height: 1.6;
  }
  .visit-cta__btn {
    background: #f9f9f9 !important;
    color: var(--accent-deep) !important;
    white-space: nowrap;
    border-radius: 0.375rem;
  }
  .visit-cta__btn:hover {
    filter: brightness(0.95) !important;
    transform: translateY(-1px);
  }

  .contato__heading {
    font-family: var(--serif);
    font-size: 32px;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }
  .contato__row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    padding: 20px 0;
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.6;
  }
  .contato__label {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    font-weight: 500;
    padding-top: 3px;
  }
  .contato__social {
    display: flex;
    gap: 16px;
    margin-top: 16px;
  }
  .contato__social a {
    color: var(--ink-soft);
    transition: color var(--t-fast);
    line-height: 0;
  }
  .contato__social a:hover { color: var(--accent); }

  @media (max-width: 820px) {
    .visit-cta__box {
      grid-template-columns: 1fr;
      padding: 48px 36px;
    }
    .contato__grid { margin-top: 56px; }
  }
</style>
