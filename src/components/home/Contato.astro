---
import { Icon } from 'astro-icon/components';
---

<section class="section" id="contato" aria-labelledby="contato-titulo">
  <div class="container">
    <!-- Visit CTA box -->
    <div class="reveal visit-cta__box">
      <div>
        <span class="kicker" style="color: var(--bg);">Primeira vez?</span>
        <h2 class="visit-cta__title">
          A gente preparou<br />uma página <em>só pra você</em>.
        </h2>
        <p class="visit-cta__lede">
          Respondemos as perguntas que mais ouvimos: o que vestir, quanto tempo dura, se tem
          estacionamento, se vão te pressionar. (Não vão.)
        </p>
      </div>
      <a href="#" class="btn visit-cta__btn">
        Quero conhecer <span class="arr">→</span>
      </a>
    </div>

    <!-- Location + map -->
    <div class="grid-2 contato__grid" style="margin-top: 80px; align-items: center;">
      <div class="reveal contato__info">
        <h2 id="contato-titulo" class="contato__heading">Nossa Localização</h2>

        <div class="contato__row">
          <div class="contato__label">Endereço</div>
          <div>
            <p>Rua Garibaldi, 216</p>
            <p>Niterói · Canoas — RS</p>
          </div>
        </div>

        <div class="contato__row">
          <div class="contato__label">Contato</div>
          <div>
            <p>Entre em contato para mais informações sobre as atividades.</p>
            <div class="contato__social">
              <a href="tel:#" title="Telefone" aria-label="Telefone">
                <Icon name="lucide:phone" size={20} />
              </a>
              <a
                href="https://instagram.com/iasdniteroi"
                target="_blank"
                rel="noopener noreferrer"
                title="Instagram"
                aria-label="Instagram"
              >
                <Icon name="lucide:instagram" size={20} />
              </a>
              <a
                href="https://youtube.com/@iasdniteroi"
                target="_blank"
                rel="noopener noreferrer"
                title="YouTube"
                aria-label="YouTube"
              >
                <Icon name="lucide:youtube" size={20} />
              </a>
              <a
                href="https://wa.me/5551999999999"
                target="_blank"
                rel="noopener noreferrer"
                title="WhatsApp"
                aria-label="WhatsApp"
              >
                <Icon name="lucide:message-circle-more" size={20} />
              </a>
            </div>
          </div>
        </div>

        <a
          href="https://www.google.com/maps/search/?api=1&query=Rua+Garibaldi+216+Niter%C3%B3i+Canoas+RS"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary"
          style="margin-top: 32px;"
        >
          Ver no Mapa <span class="arr">→</span>
        </a>
      </div>

      <div class="reveal contato__map" style="transition-delay: 150ms">
        <div class="framed" style="height: 420px;">
          <iframe
            title="Mapa de localização IASD Niterói"
            src="https://www.openstreetmap.org/export/embed.html?bbox=-51.1759,-29.9575,-51.1717,-29.9553&layer=mapnik&marker=-29.9564,-51.1738"
            width="100%"
            height="100%"
            style="border: 0; display: block; filter: grayscale(0.4) contrast(1.05);"
            loading="lazy"
            referrerpolicy="no-referrer"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .visit-cta__box {
    background: linear-gradient(45deg, var(--accent-deep) 0%, var(--accent) 100%);
    color: var(--bg);
    padding: 72px 64px;
    border-radius: 0.75rem;
    display: grid;
    grid-template-columns: 1.3fr auto;
    gap: 48px;
    align-items: end;
  }
  .visit-cta__title {
    font-family: var(--serif);
    font-size: clamp(28px, 3.5vw, 46px);
    font-weight: 400;
    color: var(--bg);
    margin-top: 14px;
    letter-spacing: -0.015em;
    line-height: 1.1;
  }
  .visit-cta__title em {
    font-style: italic;
    color: var(--gold);
  }
  .visit-cta__lede {
    margin-top: 20px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 17px;
    max-width: 50ch;
    line-height: 1.6;
  }
  .visit-cta__btn {
    background: #f9f9f9 !important;
    color: var(--accent-deep) !important;
    white-space: nowrap;
    border-radius: 0.375rem;
  }
  .visit-cta__btn:hover {
    filter: brightness(0.95) !important;
    transform: translateY(-1px);
  }

  .contato__heading {
    font-family: var(--serif);
    font-size: 32px;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }
  .contato__row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    padding: 20px 0;
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.6;
  }
  .contato__label {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    font-weight: 500;
    padding-top: 3px;
  }
  .contato__social {
    display: flex;
    gap: 16px;
    margin-top: 16px;
  }
  .contato__social a {
    color: var(--ink-soft);
    transition: color var(--t-fast);
    line-height: 0;
  }
  .contato__social a:hover {
    color: var(--accent);
  }

  @media (max-width: 820px) {
    .visit-cta__box {
      grid-template-columns: 1fr;
      padding: 48px 36px;
    }
    .contato__grid {
      margin-top: 56px;
    }
  }
</style>
