<section class="reflexao">
  <div class="container">
    <div class="reveal reflexao__inner">
      <blockquote class="reflexao__quote">
        <span
          >"Porque, onde estiverem dois ou três reunidos em meu nome, aí estou eu no meio deles."</span
        >
        <cite>Mateus 18:20</cite>
      </blockquote>
    </div>
  </div>
</section>

<style>
  .reflexao {
    background: #1d3644;
    padding: 7rem 0;
  }
  .reflexao__inner {
    text-align: center;
  }
  .reflexao__quote {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(22px, 2.8vw, 34px);
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.4;
    letter-spacing: -0.01em;
    max-width: 32ch;
    margin: 0 auto;
  }
  .reflexao__quote cite {
    display: block;
    margin-top: 20px;
    font-style: normal;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #c4a96e;
    font-weight: 500;
  }
</style>
