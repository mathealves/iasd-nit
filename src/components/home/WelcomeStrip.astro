<section class="welcome-strip">
  <div class="container">
    <div class="reveal">
      <p class="welcome-strip__text">
        <span class="serif italic">Não importa</span> de onde você vem,
        no que você acredita hoje, ou há quanto tempo você não entra numa
        igreja. <span class="serif italic">Você é bem-vindo aqui.</span>
      </p>
    </div>
  </div>
</section>

<style>
  .welcome-strip {
    padding: 80px 0;
    background: var(--bg-soft);
  }
  .welcome-strip__text {
    font-family: var(--serif);
    font-size: clamp(22px, 2.6vw, 32px);
    line-height: 1.4;
    letter-spacing: -0.01em;
    text-align: center;
    max-width: 28ch;
    margin: 0 auto;
    color: var(--ink);
  }
  .welcome-strip__text .italic { color: var(--accent); }
</style>
