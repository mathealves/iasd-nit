---

<section class="bg-tertiary-container text-on-tertiary-container py-24" aria-labelledby="departamentos-titulo">
  <div class="max-w-7xl mx-auto px-8">
    <div class="mb-16">
      <h2 id="departamentos-titulo" class="noto-serif text-4xl text-on-tertiary mb-4 font-bold">
        Departamentos
      </h2>
      <p class="manrope text-tertiary-fixed-dim">Conheça algumas de nossas atividades</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {
        departamentos.map((dep) => (
          <div class="group">
            <div class="mb-6 overflow-hidden rounded-xl">
              <img
                src={dep.imgSrc}
                alt={dep.imgAlt}
                class="w-full h-48 object-cover transition-transform duration-700 group-hover:scale-110"
              />
            </div>
            <h4 class="noto-serif text-2xl text-on-tertiary mb-2 font-bold">{dep.titulo}</h4>
            <p class="manrope text-sm mb-4 leading-relaxed text-on-tertiary-container/80">
              {dep.descricao}
            </p>
            <a
              href="#"
              class="inline-flex items-center text-secondary-fixed text-xs font-bold tracking-widest uppercase hover:text-on-tertiary transition-colors"
            >
              {dep.ctaLabel}
              <span class="material-symbols-outlined ml-2 text-sm">arrow_forward</span>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
