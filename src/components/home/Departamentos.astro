  {
    titulo: 'Jovens Niterói',
    descricao: 'Culto Jovem aos sábados às 17:00. Integração e louvor contemporâneo.',
    ctaLabel: 'Participar',
    imgSrc: 'https://lh3.googleusercontent.com/aida/ADBb0ugLNad63_HEO_3TLQ69svI4r1aHBSqLD-12ZEys-0gwV_S_tKJV8L0d611GJJ4y94Ne3nG3urx5ZAglb82g9Bau0lmgF4fNW8fqUSnE5q5p_0Xf2-ca1GxAgM3lcnxoX54YMmxibGl9_7NvLdZeRmgctDRua9aMCJuB6L3dU3C973LjJVCc9N2YzhloXkrI9zI8teDBjKS7FURPVE0L9YAg09Z3f77o8xbLksj5f5bgwA294HGIbc9uiSDxC7XoXcSZUnGE1qtF2_c',
    imgAlt: 'Jovens Niterói',
  },
  {
    titulo: 'Clube de Desbravadores',
    descricao: 'Reuniões aos domingos às 09:00. Atividades ao ar livre e civismo.',
    ctaLabel: 'Conhecer Clube',
    imgSrc: 'https://lh3.googleusercontent.com/aida/ADBb0ui5oq5p5VDlkrSUKuXPCCDDrX33-s8xEUs7QcSP-OX8C_rWf2kdwwY1H3FKYcJKDUYW1Nug9FRlg6yzmyDnqOaRnsCkBwCJhgC2EFyqHvEo0zidwfHLcuzmwga3qflptvHw968tvUCpE413tVweBBmBHgRp6lpTfn-MZdvjbb1kfdRX_lE79bHxYE2zEQkI6B8bxEx9Zj_wKi0O_JVjEueWcUWu3Zab2wg2mS1YNrAQxhMZOpjkUzDKS-ObpENYKSRr_zda8FDkfno',
    imgAlt: 'Clube de Desbravadores',
  },
