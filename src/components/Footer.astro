---
import { Image } from 'astro:assets';
import logoSrc from '../assets/adventist_symbol_denim.png';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <div class="footer__brand-logo">
          <Image src={logoSrc} alt="Logo IASD" class="nav__brand-mark" width={32} height={32} />
          <span class="footer__brand-text">
            <b>IASD Niterói</b>
            <span>Canoas · RS</span>
          </span>
        </div>
        <p>Uma comunidade adventista no bairro Niterói, em Canoas — RS. Aqui há lugar para você.</p>
      </div>

      <!-- Visite -->
      <div class="footer__col">
        <h4>Visite</h4>
        <ul>
          <li>Quarta · 20h Culto Divino</li>
          <li>Sábado · 9h Escola Sabatina</li>
          <li>Sábado · 10h30 Culto Divino</li>
          <li>Quarta · 20h Culto Divino</li>
        </ul>
      </div>

      <!-- Endereço -->
      <div class="footer__col">
        <h4>Endereço</h4>
        <ul>
          <li>Rua Garibaldi, 216</li>
          <li>Niterói · Canoas — RS</li>
          <li>
            <a
              href="https://maps.google.com/maps?q=Rua+Garibaldi+216+Niterói+Canoas+RS"
              target="_blank"
              rel="noopener noreferrer">Ver no mapa →</a
            >
          </li>
        </ul>
      </div>

      <!-- Contato -->
      <div class="footer__col">
        <h4>Contato</h4>
        <ul>
          <li>
            <a
              href="https://www.instagram.com/adventistasniteroi/"
              target="_blank"
              rel="noopener noreferrer">Instagram</a
            >
          </li>
          <li>
            <a href="https://www.youtube.com/@advnit" target="_blank" rel="noopener noreferrer"
              >YouTube</a
            >
          </li>
          <li>
            <a href="https://wa.me/5551999999999" target="_blank" rel="noopener noreferrer"
              >WhatsApp</a
            >
          </li>
          <li><a href="#">Quero conhecer</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <span>© {year} Igreja Adventista do Sétimo Dia · Niterói, Canoas — RS</span>
    </div>
  </div>
</footer>

<style>
  @font-face {
    font-family: 'AdventSans Logo';
    src: url('/fonts/AdventSans-Logo.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
  .footer {
    padding: 80px 0 32px;
    border-top: 1px solid var(--line);
    background: var(--bg-soft);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 56px;
    margin-bottom: 64px;
  }
  .footer__brand-logo {
    font-family: 'AdventSans Logo', var(--serif);
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .footer__brand-text {
    font-family: 'AdventSans Logo', var(--serif);
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .footer__brand-text span {
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-top: 2px;
  }
  .footer__brand p {
    color: var(--ink-soft);
    font-size: 14px;
    max-width: 28ch;
    line-height: 1.6;
  }

  .footer__col h4 {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 18px;
    font-weight: 500;
  }
  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer__col li {
    color: var(--ink-soft);
    font-size: 14px;
  }
  .footer__col a {
    color: var(--ink-soft);
    transition: color var(--t-fast);
  }
  .footer__col a:hover {
    color: var(--ink);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    font-size: 12px;
    color: var(--ink-mute);
  }
  .footer__lang {
    display: flex;
    gap: 14px;
  }
  .footer__lang button {
    background: none;
    border: 0;
    color: var(--ink-mute);
    cursor: pointer;
    padding: 0;
    font-size: 12px;
    font-family: var(--sans);
    letter-spacing: 0.06em;
    transition: color var(--t-fast);
  }
  .footer__lang button:hover,
  .footer__lang button.active {
    color: var(--ink);
  }

  @media (max-width: 820px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .footer__bottom {
      flex-direction: column;
      gap: 14px;
      align-items: flex-start;
    }
  }
  @media (max-width: 480px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
