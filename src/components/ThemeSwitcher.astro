---
// DEV-ONLY component: only rendered in development mode (import.meta.env.DEV check is in parent)
const temas = [
  { id: 'default', label: 'Roxo', color: '#7C3AED' },
  { id: 'verde', label: 'Verde', color: '#059669' },
  { id: 'laranja', label: 'Laranja', color: '#EA580C' },
  { id: 'sobrio', label: 'Sóbrio', color: '#1E40AF' },
] as const;
---

<div
  id="theme-switcher"
  class="fixed bottom-5 right-5 z-50 bg-white border border-gray-200 rounded-2xl shadow-2xl p-4 flex flex-col gap-3 select-none"
>
  <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest text-center"
    >DEV · Temas</span
  >
  <div class="flex gap-2 justify-center">
    {
      temas.map((tema) => (
        <button
          data-theme-id={tema.id}
          title={tema.label}
          style={`background-color: ${tema.color};`}
          class="theme-btn w-8 h-8 rounded-full border-2 border-white shadow-md hover:scale-110 transition-transform focus-visible:outline-none"
          aria-label={`Tema ${tema.label}`}
        />
      ))
    }
  </div>
  <span id="theme-label" class="text-[10px] text-gray-400 text-center">Roxo</span>
</div>

<script>
  type ThemeId = 'default' | 'verde' | 'laranja' | 'sobrio';

  const themeLabels: Record<ThemeId, string> = {
    default: 'Roxo',
    verde: 'Verde',
    laranja: 'Laranja',
    sobrio: 'Sóbrio',
  };

  function applyTheme(themeId: ThemeId) {
    const html = document.documentElement;
    if (themeId === 'default') {
      html.removeAttribute('data-theme');
    } else {
      html.setAttribute('data-theme', themeId);
    }
    localStorage.setItem('iasd-theme', themeId);

    const label = document.getElementById('theme-label');
    if (label) label.textContent = themeLabels[themeId];

    document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
      const isActive = btn.dataset.themeId === themeId;
      btn.style.outline = isActive ? '3px solid rgba(0,0,0,0.25)' : 'none';
      btn.style.outlineOffset = '2px';
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.themeId as ThemeId;
      if (id) applyTheme(id);
    });
  });

  // Reflect currently active theme
  const saved = (localStorage.getItem('iasd-theme') ?? 'default') as ThemeId;
  applyTheme(saved);
</script>
