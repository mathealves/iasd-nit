---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';

const VALORES = [
  {
    t: "Conversa real",
    d: "Sem respostas decoradas. A gente fala sobre fé, mas também sobre ansiedade, faculdade, namoro, futuro — tudo.",
  },
  {
    t: "Espaço seguro",
    d: "Você pode duvidar, perguntar, discordar. Ninguém vai te corrigir em voz alta. A dúvida faz parte.",
  },
  {
    t: "Comunidade que aparece",
    d: "Quando alguém precisa, a gente aparece — no hospital, na mudança, no aniversário, no dia comum.",
  },
];

const AGENDA = [
  {
    dia: "Sáb",
    hora: "19h30",
    titulo: "Culto Jovem",
    local: "Templo principal",
    desc: "Música, mensagem curta, espaço pra ficar conversando depois.",
  },
  {
    dia: "Ter",
    hora: "20h00",
    titulo: "Pequeno Grupo",
    local: "Casas rotativas",
    desc: "Estudo da Bíblia em grupos de 8 a 12 pessoas. Tem café.",
  },
  {
    dia: "Sáb",
    hora: "15h00",
    titulo: "Esporte + Convívio",
    local: "Quadra do colégio",
    desc: "Vôlei, futebol, conversa. Aberto pra quem quiser, traga amigos.",
  },
];

const PROJETOS = [
  {
    t: "Mochila Cheia",
    d: "Arrecadação anual de material escolar para escolas públicas do bairro.",
    img: "https://images.unsplash.com/photo-1497486751825-1233686d5d80?w=800&q=80",
  },
  {
    t: "Café com a Vó",
    d: "Visitas mensais a casas de repouso, com música e conversa.",
    img: "https://images.unsplash.com/photo-1551434678-e076c223a692?w=800&q=80",
  },
  {
    t: "Acampamento de Inverno",
    d: "Encontro anual de três dias na serra gaúcha — desde 1998.",
    img: "https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=800&q=80",
  },
];
---

<BaseLayout
  title="Ministério Jovens — IASD Niterói"
  description="Adolescentes e jovens adultos, com fé e com dúvida. A gente se reúne porque acredita que a vida dos vinte e poucos não precisa ser vivida sozinha."
>
  <NavBar />
  <main>
    <!-- Hero -->
    <section class="page-hero ministry-hero">
      <div class="container ministry-hero__inner">
        <div>
          <span class="kicker reveal">Ministério</span>
          <h1 class="page-hero__title reveal">
            Jovens.<br /><em>Sem roteiro decorado.</em>
          </h1>
          <p class="page-hero__lede reveal">
            A gente se reúne porque acredita que a vida dos vinte e poucos
            não precisa ser vivida sozinha. Adolescentes e jovens adultos,
            com fé e com dúvida, com tudo resolvido e com nada resolvido.
          </p>
          <div class="hero__actions reveal">
            <a href="#agenda" class="btn btn--primary">Veja os encontros <span class="arr">→</span></a>
            <a href="#projetos" class="btn btn--ghost">Nossos projetos</a>
          </div>
        </div>
        <div class="framed ministry-hero__media reveal">
          <Image
            src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=1200&q=80"
            alt="Jovens da IASD Niterói"
            inferSize
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- Valores -->
    <section class="section">
      <div class="container">
        <div class="section__head section__head--center">
          <span class="kicker">No que a gente acredita</span>
          <h2 class="section__title">Três coisas, sempre.</h2>
        </div>
        <div class="grid-3 valores">
          {VALORES.map((v, i) => (
            <div class="valor reveal">
              <div class="valor__num">0{i + 1}</div>
              <h3 class="valor__t">{v.t}</h3>
              <p>{v.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Agenda -->
    <section class="section agenda-section" id="agenda">
      <div class="container">
        <div class="section__head">
          <span class="kicker">Quando a gente se vê</span>
          <h2 class="section__title">Três encontros por semana.</h2>
        </div>
        <div class="agenda">
          {AGENDA.map((a) => (
            <div class="agenda__row reveal">
              <div class="agenda__when">
                <div class="agenda__dia">{a.dia}</div>
                <div class="agenda__hora">{a.hora}</div>
              </div>
              <div class="agenda__main">
                <h3 class="agenda__t">{a.titulo}</h3>
                <p>{a.desc}</p>
              </div>
              <div class="agenda__local">{a.local}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Projetos -->
    <section class="section projetos-section" id="projetos">
      <div class="container">
        <div class="section__head">
          <span class="kicker">Projetos</span>
          <h2 class="section__title">O que sai daqui<br /><em>e vai pro mundo</em>.</h2>
        </div>
        <div class="projetos">
          {PROJETOS.map((p) => (
            <div class="projeto reveal">
              <div class="framed projeto__media">
                <Image src={p.img} alt="" inferSize loading="lazy" />
              </div>
              <h3 class="projeto__t">{p.t}</h3>
              <p>{p.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section visit-cta">
      <div class="container">
        <div class="visit-cta__box reveal">
          <div>
            <span class="kicker" style="color: var(--bg);">Quer ir num sábado à noite?</span>
            <h2 class="section__title" style="color: var(--bg);">
              Aparece.<br /><em style="color: var(--gold);">A gente guarda lugar.</em>
            </h2>
            <p class="visit-cta__lede">
              Sábado, 19h30, no templo. Não precisa avisar. Se quiser, manda
              uma mensagem antes — a gente pode te encontrar na entrada.
            </p>
          </div>
          <a href="/quero-conhecer" class="btn visit-cta__btn">
            Como chegar <span class="arr">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .ministry-hero { border-bottom: 1px solid var(--line); padding-bottom: 100px; }
  .ministry-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .ministry-hero__media { aspect-ratio: 4/5; }

  /* ── Valores ── */
  .valor {
    padding: 40px 32px;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 4px;
    height: 100%;
    transition: border-color var(--t-fast), transform var(--t-fast);
  }
  .valor:hover { border-color: var(--line-strong); transform: translateY(-2px); }
  .valor__num {
    font-family: var(--serif);
    font-size: 14px;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 22px;
  }
  .valor__t {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }
  .valor p { font-size: 15px; color: var(--ink-soft); line-height: 1.65; }

  /* ── Agenda ── */
  .agenda-section { background: var(--bg-soft); }
  .agenda { border-top: 1px solid var(--line-strong); }
  .agenda__row {
    display: grid;
    grid-template-columns: 140px 1fr 200px;
    gap: 32px;
    padding: 32px 8px;
    border-bottom: 1px solid var(--line-strong);
    align-items: center;
    transition: padding-left var(--t-fast);
  }
  .agenda__row:hover { padding-left: 20px; }
  .agenda__dia {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .agenda__hora {
    font-family: var(--serif);
    font-size: 32px;
    color: var(--accent);
    margin-top: 4px;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.01em;
  }
  .agenda__t {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 400;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .agenda__main p { font-size: 14.5px; color: var(--ink-soft); line-height: 1.6; max-width: 56ch; }
  .agenda__local { font-size: 13px; color: var(--ink-mute); text-align: right; letter-spacing: 0.04em; }

  /* ── Projetos ── */
  .projetos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 56px;
  }
  .projeto__media { aspect-ratio: 4/3; margin-bottom: 22px; }
  .projeto__t {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 400;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .projeto p { font-size: 14.5px; color: var(--ink-soft); line-height: 1.6; }

  /* ── Visit CTA ── */
  .visit-cta__box {
    background: var(--accent-deep);
    color: var(--bg);
    padding: 72px 64px;
    border-radius: 4px;
    display: grid;
    grid-template-columns: 1.3fr auto;
    gap: 48px;
    align-items: end;
  }
  .visit-cta__lede {
    margin-top: 20px;
    color: rgba(255,255,255,0.78);
    font-size: 17px;
    max-width: 50ch;
    line-height: 1.6;
  }
  .visit-cta__btn {
    background: var(--bg) !important;
    color: var(--accent-deep) !important;
    border-color: var(--bg) !important;
    white-space: nowrap;
  }
  .visit-cta__btn:hover {
    background: var(--gold) !important;
    color: var(--accent-deep) !important;
    border-color: var(--gold) !important;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .ministry-hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .agenda__row { grid-template-columns: 1fr; gap: 8px; padding: 24px 4px; }
    .agenda__local { text-align: left; }
  }
  @media (max-width: 820px) {
    .projetos { grid-template-columns: 1fr; }
    .visit-cta__box { grid-template-columns: 1fr; padding: 48px 36px; }
  }
</style>
