const AGENDA = [
  {
    dia: 'SAB',
    hora: '19h30',
    titulo: 'Culto Jovem',
    local: 'Templo principal',
    desc: 'Música ao vivo, mensagem direta, papo aberto depois.',
    tag: 'Semanal',
  },
  {
    dia: 'TER',
    hora: '20h00',
    titulo: 'Grupo Pequeno',
    local: 'Casas rotativas',
    desc: 'Estudo da Bíblia em grupos de 8 a 12 pessoas. Tem café. Sempre.',
    tag: 'Semanal',
  },
  {
    dia: 'SAB',
    hora: '15h00',
    titulo: 'Esporte + Convívio',
    local: 'Quadra do colégio',
    desc: 'Vôlei, futebol, conversa. Traga amigos — sem convite formal.',
    tag: 'Semanal',
  },
];

const PROJETOS = [
  {
    t: 'Mochila Cheia',
    d: 'Arrecadação anual de material escolar para escolas públicas do bairro.',
    emoji: '🎒',
  },
  {
    t: 'Café com a Vó',
    d: 'Visitas mensais a casas de repouso, com música e conversa real.',
    emoji: '☕',
  },
  {
    t: 'Acampamento de Inverno',
