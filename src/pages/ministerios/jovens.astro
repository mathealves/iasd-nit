              </div>
            ))
          }
        </div>
      </div>
    </section> -->

    <!-- ───────────────────── AGENDA ───────────────────── -->
    <!-- <section class="jv-section jv-agenda-section" id="agenda" aria-labelledby="jv-agenda-titulo">
      <div class="jv-container">
        <div class="jv-section__head">
          <p class="jv-kicker">Quando a gente se vê</p>
          <h2 id="jv-agenda-titulo" class="jv-section-title">
            Toda semana.<br />
            <span class="jv-accent-text">Sem falta.</span>
          </h2>
        </div>
        <div class="jv-agenda">
          {
            AGENDA.map((a) => (
              <div class="jv-agenda__item">
                <div class="jv-agenda__when">
                  <span class="jv-agenda__dia">{a.dia}</span>
                  <span class="jv-agenda__hora">{a.hora}</span>
                </div>
                <div class="jv-agenda__body">
                  <div class="jv-agenda__top">
                    <h3 class="jv-agenda__titulo">{a.titulo}</h3>
                    <span class="jv-agenda__tag">{a.tag}</span>
                  </div>
                  <p class="jv-agenda__desc">{a.desc}</p>
                  <p class="jv-agenda__local">📍 {a.local}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section> -->

    <!-- ───────────────────── PROJETOS ───────────────────── -->
    <!-- <section class="jv-section jv-projetos-section" id="projetos" aria-labelledby="jv-projetos-titulo">
      <div class="jv-container">
        <div class="jv-section__head">
          <p class="jv-kicker">De dentro pra fora</p>
          <h2 id="jv-projetos-titulo" class="jv-section-title">
            O que sai daqui<br />
            <span class="jv-accent-text">e vai pro mundo.</span>
          </h2>
        </div>
        <div class="jv-projetos">
          {
            PROJETOS.map((p) => (
              <div class="jv-projeto">
                <span class="jv-projeto__emoji">{p.emoji}</span>
                <h3 class="jv-projeto__t">{p.t}</h3>
                <p class="jv-projeto__d">{p.d}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section> -->

    <!-- ───────────────────── CTA ───────────────────── -->
    <section id="proximo-passo" class="jv-cta-section" aria-labelledby="jv-cta-titulo">
      <div class="jv-cta__inner">
        <p class="jv-kicker">Próximo passo</p>
        <h2 id="jv-cta-titulo" class="jv-cta__title">
          Aparece um sábado.<br />
          <span class="jv-accent-text">Sem aviso prévio.</span>
        </h2>
        <p class="jv-cta__lede">
          Você não precisa conhecer ninguém, nem avisar que vai aparecer. Será bem recebido e acolhido aqui!  
        </p>
        <!-- <div class="jv-cta__actions">
          <a href="/quero-conhecer" class="jv-btn jv-btn--primary jv-btn--lg">
            Como chegar →
          </a>
          <a
            href="https://wa.me/5521900000000"
            class="jv-btn jv-btn--outline jv-btn--lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Fala com a gente
          </a>
        </div> -->
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════
     TOKENS LOCAIS — paleta inspirada na identidade visual CUT
     Lima (#7de83a) + Navy (#0d1454) sobre fundo do site (--bg)
  ══════════════════════════════════════════════ */
  .jv-page {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans, 'Noto Sans', sans-serif);

    --jv-green: #7de83a;
    --jv-green-dark: #5cc020;
    --jv-navy: #0d1454;
    --jv-navy-soft: #1a2472;
    --jv-surface: #f3f3f3;
    --jv-border: rgba(13, 20, 84, 0.12);
    --jv-radius: 14px;
    --jv-gutter: clamp(20px, 5vw, 80px);
  }

  /* ── Texto accent (verde lima) ── */
  .jv-accent-text {
    color: var(--jv-green-dark);
  }

  /* ── Kicker ── */
  .jv-kicker {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--jv-navy-soft);
    margin-bottom: 14px;
    opacity: 0.65;
  }

  /* ── Botões ── */
  .jv-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 24px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: all 220ms ease;
    cursor: pointer;
    border: 2px solid transparent;
  }
  .jv-btn--primary {
    background: var(--jv-navy);
    color: var(--jv-green);
    border-color: var(--jv-navy);
  }
  .jv-btn--primary:hover {
    background: var(--jv-green);
    color: var(--jv-navy);
    border-color: var(--jv-green);
  }
  .jv-btn--outline {
    background: transparent;
    color: var(--jv-navy);
    border-color: var(--jv-navy);
  }
  .jv-btn--outline:hover {
    background: var(--jv-navy);
    color: var(--jv-green);
  }
  .jv-btn--lg {
    padding: 16px 32px;
    font-size: 16px;
  }

  /* ── Container ── */
  .jv-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--jv-gutter);
  }

  /* ── Section base ── */
  .jv-section {
    padding: clamp(64px, 10vw, 120px) 0;
  }
  .jv-section__head {
    max-width: 580px;
    margin-bottom: clamp(48px, 7vw, 80px);
  }
  .jv-section-title {
    font-size: clamp(32px, 5vw, 54px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
  }


  /* ══════════════════════════════════════════════
     HERO
  ══════════════════════════════════════════════ */
  .jv-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    /* overflow-x hidden corta as laterais mas a seção seguinte é que mostra o overflow vertical */

    /* padding: clamp(100px, 14vw, 160px) 0 clamp(40px, 6vw, 60px); */
    z-index: 2;
  }

  /* Grid ocupa a largura total da viewport — logo fica em 50vw real */
  .jv-hero__inner {
    width: 100%;
    align-self: stretch; /* estica para preencher toda a altura do flex pai */
    display: grid;
    grid-template-columns: 50vw 1fr;
    align-items: center;
  }

  /* ── Logo wrap: toma a coluna de 50vw inteira ── */
  .jv-hero__logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow-x: clip;   /* corta laterais sem criar scroll container */
    overflow-y: visible; /* logo pode sangrar para baixo */
    align-self: stretch;
    padding: clamp(16px, 2vw, 32px) 0;
  }

  .jv-hero__logo {
    /* Maior que a coluna para que as bordas sejam cortadas */
    width: clamp(480px, 56vw, 800px);
    height: auto;
    flex-shrink: 0;
    transform: rotate(-7deg);
    transform-origin: center center;
    animation: jv-spin-in 1.3s cubic-bezier(0.16, 1, 0.3, 1) both;
    filter: drop-shadow(0 16px 48px rgba(93, 192, 32, 0.3));
    position: relative;
    z-index: 3;
  }

  @keyframes jv-spin-in {
    from {
      transform: translate(-160%, -140%) rotate(-720deg) scale(0.15);
      opacity: 0;
    }
    to {
      transform: translate(0, 0) rotate(-7deg) scale(1);
      opacity: 1;
    }
  }

  /* ── Hero text ── */
  .jv-hero__text {
    animation: jv-fade-up 0.9s 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    position: relative;
    z-index: 2;
    padding-right: clamp(32px, 5vw, 80px);
  }

  @keyframes jv-fade-up {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .jv-hero__title {
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .jv-hero__lede {
    font-size: clamp(16px, 2vw, 18px);
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 44ch;
    margin-bottom: 36px;
  }

  .jv-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }


  /* ══════════════════════════════════════════════
     SEÇÕES DE VÍDEO — vídeo É a lateral da seção
  ══════════════════════════════════════════════ */
  .jv-media-section {
    position: relative;
    min-height: clamp(480px, 60vw, 700px);
    display: flex;
    overflow: hidden;
    background: var(--bg);
  }

  /* Variante: vídeo à direita (texto esquerda) */
  .jv-media-section--right {
    flex-direction: row;
  }
  /* Variante: vídeo à esquerda (texto direita) */
  .jv-media-section--left {
    flex-direction: row;
    background: var(--jv-surface);
  }

  /* ── Conteúdo textual (60%) ── */
  .jv-media__content {
    flex: 0 0 60%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(48px, 7vw, 100px) clamp(32px, 5vw, 80px);
    position: relative;
    z-index: 1;
  }
  .jv-media__content--alt {
    padding-left: clamp(40px, 6vw, 100px);
  }

  .jv-media__lede {
    font-size: clamp(15px, 1.8vw, 17px);
    line-height: 1.72;
    color: var(--ink-soft);
    max-width: 48ch;
    margin-bottom: 12px;
  }
  .jv-media__sub {
    font-size: 14px;
    color: var(--ink-mute);
    margin-bottom: 32px;
  }

  .jv-media__content .jv-section-title {
    margin-bottom: 20px;
  }

  /* ── Vídeo (40%): ocupa TODA a altura da seção ── */
  .jv-media__video-wrap {
    flex: 0 0 40%;
    position: relative;
    overflow: hidden;
  }

  .jv-media__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Barra colorida de separação */
  .jv-media-section--right .jv-media__video-wrap::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 4px;
    height: 100%;
    background: var(--jv-green);
    z-index: 2;
  }
  .jv-media-section--left .jv-media__video-wrap::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    width: 4px;
    height: 100%;
    background: var(--jv-navy);
    z-index: 2;
  }


  /* ══════════════════════════════════════════════
     PARALLAX FOTO
  ══════════════════════════════════════════════ */
  .jv-parallax {
    height: clamp(320px, 55vw, 600px);
    background-attachment: fixed;
    background-size: cover;
    background-position: center 1%;
    background-repeat: no-repeat;
  }

  @media (max-width: 768px) {
    /* background-attachment: fixed não funciona bem em iOS; usa scroll normal */
    .jv-parallax {
      background-attachment: scroll;
    }
  }

  /* ══════════════════════════════════════════════
     VALORES
  ══════════════════════════════════════════════ */
  .jv-valores-section {
    border-top: 1px solid var(--jv-border);
  }

  .jv-valores {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .jv-valor {
    background: var(--bg-card, #fff);
    border: 1px solid var(--jv-border);
    border-radius: var(--jv-radius);
    padding: clamp(28px, 3vw, 40px);
    transition: border-color 220ms ease, transform 220ms ease, box-shadow 220ms ease;
  }
  .jv-valor:hover {
    border-color: var(--jv-green);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(125, 232, 58, 0.15);
  }
  .jv-valor__num {
    display: block;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: var(--jv-green-dark);
    margin-bottom: 20px;
  }
  .jv-valor__t {
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .jv-valor__d {
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--ink-soft);
  }


  /* ══════════════════════════════════════════════
     AGENDA
  ══════════════════════════════════════════════ */
  .jv-agenda-section {
    background: var(--jv-navy);
    color: #fff;
  }
  .jv-agenda-section .jv-section-title {
    color: #fff;
  }
  .jv-agenda-section .jv-kicker {
    color: var(--jv-green);
    opacity: 1;
  }

  .jv-agenda {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .jv-agenda__item {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 32px;
    align-items: start;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--jv-radius);
    padding: clamp(20px, 3vw, 32px);
    transition: border-color 220ms ease, background 220ms ease;
  }
  .jv-agenda__item:hover {
    border-color: var(--jv-green);
    background: rgba(125, 232, 58, 0.06);
  }

  .jv-agenda__when {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .jv-agenda__dia {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.22em;
    color: var(--jv-green);
    opacity: 0.8;
  }
  .jv-agenda__hora {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--jv-green);
    line-height: 1;
  }
  .jv-agenda__top {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .jv-agenda__titulo {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .jv-agenda__tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 3px 10px;
    border-radius: 100px;
  }
  .jv-agenda__desc {
