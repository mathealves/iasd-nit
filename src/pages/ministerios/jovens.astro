import video1 from '../../assets/jovens-1.mp4';
import video2 from '../../assets/jovens-2.mp4';
import jovensNit from '../../assets/jovens-nit.jpg';

const VALORES = [
  {
    num: '01',
    t: 'Fé que respira',
    d: 'A gente não tem todas as respostas, e tudo bem. Falar sobre dúvida aqui é tão válido quanto falar sobre fé.',
